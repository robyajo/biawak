{
  "name": "create-biawak-app",
  "version": "1.0.3",
  "type": "module",
  "description": "High-Performance RESTful API & Real-Time Boilerplate powered by Hono, Bun, SQLite & MySQL",
  "author": "robyajo",
  "license": "MIT",
  "main": "src/index.ts",
  "bin": {
    "create-biawak-app": "bin/create-biawak-app.js",
    "biawak-make": "bin/biawak-make.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robyajo/biawak.git"
  },
  "homepage": "https://github.com/robyajo/biawak#readme",
  "keywords": [
    "biawak",
    "create-biawak-app",
    "hono",
    "bun",
    "sqlite",
    "mysql",
    "drizzle",
    "better-auth",
    "rest-api"
  ],
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun x tsc && bun -e \"import fs from 'fs'; fs.mkdirSync('dist/src/html', { recursive: true }); fs.copyFileSync('src/html/index.html', 'dist/src/html/index.html'); fs.copyFileSync('src/html/manual-book.html', 'dist/src/html/manual-book.html');\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:reset": "bun run src/db/reset.ts",
    "test": "bun test",
    "make:route": "node bin/biawak-make.js route",
    "make:middleware": "node bin/biawak-make.js middleware",
    "make:schema": "node bin/biawak-make.js schema",
    "release": "node bin/release.js"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@hono/standard-validator": "^0.2.3",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.8.0",
    "@standard-community/standard-json": "^0.3.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^11.8.0",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bun": "latest",
    "drizzle-kit": "^1.0.0-rc.4",
    "tsx": "^4.23.1"
  }
}
