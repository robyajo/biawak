{
  "name": "biawak",
  "author": "robyajo",
  "repository": {
    "type": "git",
    "url": "https://github.com/robyajo/biawak.git"
  },
  "homepage": "https://github.com/robyajo/biawak#readme",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun x tsc && bun -e \"import fs from 'fs'; fs.mkdirSync('dist/src/html', { recursive: true }); fs.copyFileSync('src/html/index.html', 'dist/src/html/index.html'); fs.copyFileSync('src/html/manual-book.html', 'dist/src/html/manual-book.html');\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "collection": "tsx scripts/generate-collection.ts",
    "collection:watch": "tsx scripts/generate-collection.ts --watch"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@hono/standard-validator": "^0.2.3",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.8.0",
    "@standard-community/standard-json": "^0.3.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.23",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^1.0.0-rc.4",
    "tsx": "^4.23.1"
  }
}